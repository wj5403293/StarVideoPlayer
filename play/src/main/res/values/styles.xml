<?xml version="1.0" encoding="utf-8"?>
<!--
    res/values/styles_settings.xml
    设置面板网格条目的公共样式
-->
<resources>

    <!-- 每个网格条目的容器 -->
    <style name="SettingItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">90dp</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_setting_item</item>
    </style>

    <!-- 图标 -->
    <style name="SettingIconStyle">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
    </style>

    <!-- 主标签 -->
    <style name="SettingLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- 当前值（副标签，主题色） -->
    <style name="SettingValueStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

</resources>